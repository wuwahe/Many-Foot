# =============================================================================
# ManyFoot 环境变量配置模板
# =============================================================================
# 说明：
#   1. 复制本文件为 .env 并填入实际值
#   2. 本文件仅作为配置参考，不会自动被 Spring Boot 加载
#   3. Spring Boot 会自动读取系统环境变量，变量名需与本文件一致
#   4. 所有带默认值的环境变量，如果不配置将使用默认值
# =============================================================================


# =============================================================================
# [核心] AI 模型配置
# =============================================================================

# AI 模型 API Key（主 provider 和 backup 共用）
# 用途：ManyFoot 使用的 OpenAI 兼容 API 的认证密钥
# 必填：是（如果不配置，AI 功能将无法工作）
MANY_FOOT_API_KEY=

# AI 模型 Base URL
# 用途：OpenAI 兼容 API 的基础地址
# 示例：https://api.openai.com/v1、https://api.moonshot.cn/v1
# 必填：是
MANY_FOOT_BASE_URL=


# =============================================================================
# [可选] 其它厂商 API Key（按需配置）
# =============================================================================
# 以下配置在 application.yml 中被注释，如需使用请取消注释并填入

# OpenAI 官方 API Key
# 用途：gpt-4o 等 OpenAI 模型
# OPENAI_KEY=

# Moonshot (Kimi) API Key
# 用途：moonshot-v1-32k 等 Kimi 模型
# MOONSHOT_KEY=

# 智谱 AI (Zhipu) API Key
# 用途：glm-4-plus 等智谱模型
# ZHIPU_KEY=

# Google Gemini API Key
# 用途：gemini-2.5-pro 等 Gemini 模型
# GEMINI_KEY=

# Anthropic Claude API Key
# 用途：claude-sonnet-4 等 Claude 模型
# ANTHROPIC_KEY=


# =============================================================================
# [搜索] 网络搜索配置
# =============================================================================

# Brave Search API Key
# 用途：ResearchRetrievalAgent 进行网页搜索
# 获取地址：https://api.search.brave.com/
# 必填：是（如果不配置，搜索功能将无法工作）
BRAVE_SEARCH_API_KEY=

# Jina AI API Key
# 用途：网页内容提取和搜索
# 获取地址：https://jina.ai/
# 必填：否（如果不配置，Jina 相关功能将无法工作）
JINA_API_KEY=


# =============================================================================
# [沙箱] Docker 沙箱配置
# =============================================================================

# Docker 主机地址
# 用途：Sandbox 代码执行需要的 Docker Daemon 连接地址
# Windows Docker Desktop: npipe:////./pipe/docker_engine
# Windows TCP (需在Docker Desktop设置中启用): tcp://localhost:2375
# Linux: unix:///var/run/docker.sock
# macOS: unix:///var/run/docker.sock
# 默认值：tcp://localhost:2375
# 必填：否
MANY_FOOT_DOCKER_HOST=tcp://localhost:2375


# =============================================================================
# [缓存] Redis 配置
# =============================================================================

# Redis 主机地址
# 默认值：localhost
# 必填：否
REDIS_HOST=localhost

# Redis 密码
# 用途：Redis 连接认证
# 注意：生产环境必须配置强密码
# 必填：否（如果 Redis 无密码可留空）
REDIS_PASSWORD=
